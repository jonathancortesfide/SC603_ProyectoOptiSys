# Rutas JSON del API: /api/... (no usar /index.html aquí; index.html es solo la UI/Swagger en el navegador).
VITE_ApiBase = "/api"
# Origen del API para el proxy de Vite (mismo host que abres en https://optisys-dcg7aqgeg9byasep.centralus-01.azurewebsites.net/index.html).
VITE_API_HOST = "https://optisys-dcg7aqgeg9byasep.centralus-01.azurewebsites.net"
VITE_Authority = "https://optisys-dcg7aqgeg9byasep.centralus-01.azurewebsites.net"
VITE_ClientId = "spaSoflithe"
VITE_RedirectUri = "http://127.0.0.1:8090/auth/callback"
VITE_ResponseType = "code"
VITE_Scope = "openid profile scope2"
VITE_PostLogoutRedirectUri = "http://127.0.0.1:8090/signout-oidc"
VITE_AppURL= "http://127.0.0.1:8090/auth/login"
# false = llamadas reales al API (levantar Softlithe.ERP.Api en 7159 y reiniciar Vite tras cambiar .env).
VITE_USE_MOCK=false

# Timeouts Axios (ms). Default: 60000 si no se define.
# Útil cuando el API tarda en catálogos (p.ej. Marcas/ObtenerMarca).
VITE_API_TIMEOUT_MS=60000

# Reemplazados por selección post-login en localStorage:
# identificadorSucursalSeleccionado, noEmpresaSeleccionada
# VITE_SUCURSAL_IDENTIFICADOR = 7
# VITE_NO_EMPRESA = 1
