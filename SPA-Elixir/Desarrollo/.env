# Rutas JSON del API: /api/... (no usar /index.html aquí; index.html es solo la UI/Swagger en el navegador).
VITE_ApiBase = "/api"
# Origen del API para el proxy de Vite (mismo host que abres en https://mi-api-421c.onrender.com/index.html).
VITE_API_HOST = "https://mi-api-421c.onrender.com"
#VITE_API_HOST = "https://localhost:44352"
VITE_Authority = "https://mi-api-421c.onrender.com"
#VITE_Authority = "https://localhost:44352"
VITE_ClientId = "spaSoflithe"
VITE_RedirectUri = "https://lensys.onrender.com/auth/callback"
#VITE_RedirectUri = "https://localhost:44352/auth/callback"
VITE_ResponseType = "code"
VITE_Scope = "openid profile scope2"
VITE_PostLogoutRedirectUri = "https://lensys.onrender.com/signout-oidc"
#VITE_PostLogoutRedirectUri = "https://localhost:44352/signout-oidc"
VITE_AppURL = "https://lensys.onrender.com/auth/login"
#VITE_AppURL = "https://localhost:44352/auth/login"
# false = llamadas reales al API (levantar Softlithe.ERP.Api en 7159 y reiniciar Vite tras cambiar .env).
VITE_USE_MOCK=false

# Timeouts Axios (ms). Default: 60000 si no se define.
# Útil cuando el API tarda en catálogos (p.ej. Marcas/ObtenerMarca).
VITE_API_TIMEOUT_MS=60000

# Reemplazados por selección post-login en localStorage:
# identificadorSucursalSeleccionado, noEmpresaSeleccionada
# VITE_SUCURSAL_IDENTIFICADOR = 7
# VITE_NO_EMPRESA = 1
